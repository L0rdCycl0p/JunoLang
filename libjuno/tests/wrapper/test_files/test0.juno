fn main() -> i32 {
    let a: i32 = 25;
    let b: i32 = 7;

    printf("=== arithmetic ===\n");

    let add: i32 = a + b;
    let sub: i32 = a - b;
    let mul: i32 = a * b;
    let div: i32 = a / b;
    let rem: i32 = a % b;

    printf("add = %d\n", add);
    printf("sub = %d\n", sub);
    printf("mul = %d\n", mul);
    printf("div = %d\n", div);
    printf("rem = %d\n", rem);

    printf("\n=== comparisons ===\n");

    if (a > b) {
        printf("a > b\n");
    }

    if (a < b) {
        printf("unexpected\n");
    } else {
        printf("else works\n");
    }

    if (a == 25) {
        printf("== works\n");
    }

    if (b != 0) {
        printf("!= works\n");
    }

    if (a >= 25) {
        printf(">= works\n");
    }

    if (b <= 7) {
        printf("<= works\n");
    }

    printf("\n=== while loop ===\n");

    let mut i: i32 = 0;

    while (i < 10) {
        printf("i = %d\n", i);
        i = i + 1;
    }

    printf("\n=== loop/break ===\n");

    let mut x: i32 = 0;

    loop {
        if (x == 5) {
            break;
        }

        printf("loop %d\n", x);
        x = x + 1;
    }

    printf("\n=== nested loops ===\n");

    let mut outer: i32 = 0;

    while (outer < 3) {

        let mut inner: i32 = 0;

        while (inner < 4) {
            printf("(%d,%d)\n", outer, inner);
            inner = inner + 1;
        }

        outer = outer + 1;
    }

    printf("\n=== pointers ===\n");

    let value: i32 = 123;

    let ptr: *i32 = &value;

    printf("value = %d\n", value);
    printf("*ptr = %d\n", *ptr);

    let copy: i32 = *ptr;

    printf("copy = %d\n", copy);

    printf("\n=== arrays ===\n");

    let numbers: [5]i32 = [10,20,30,40,50];

    printf("array created\n");

    printf("\n=== expressions ===\n");

    let expr1: i32 = (a + b) * 2;
    let expr2: i32 = a * b + 10;
    let expr3: i32 = a + b * 2;
    let expr4: i32 = (a - b) / 3;

    printf("%d\n", expr1);
    printf("%d\n", expr2);
    printf("%d\n", expr3);
    printf("%d\n", expr4);

    printf("\n=== unary ===\n");

    let neg: i32 = -a;

    printf("%d\n", neg);

    if (!(a < b)) {
        printf("not works\n");
    }

    printf("\n=== big block ===\n");

    let mut counter: i32 = 0;

    while (counter < 20) {

        if (counter % 2 == 0) {
            printf("%d even\n", counter);
        } else {
            printf("%d odd\n", counter);
        }

        counter = counter + 1;
    }

    printf("\n=== done ===\n");

    return 0;
}